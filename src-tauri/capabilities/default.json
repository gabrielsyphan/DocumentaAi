{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability for DocumentaAI (desktop)",
  "platforms": ["macOS", "windows", "linux"],
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "updater:default",
    "process:allow-restart"
  ]
}
